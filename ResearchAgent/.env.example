# ============================================
# ResearchAgent Environment Template
# Copy this file to .env and update values.
# ============================================

# Required: API key used by Gemini + embeddings
GOOGLE_API_KEY=your_google_api_key_here

# Optional: model used by manager/compliance/research agents
# Default: gemini-2.5-flash-lite
GOOGLE_GENAI_MODEL=gemini-2.5-flash-lite

# Optional: enable/disable research channels (true/false, 1/0, yes/no, on/off)
# Default: true
ENABLE_RAG_RESEARCH=true
# Default: true
ENABLE_WEB_RESEARCH=true

# Optional: embedding model for RAG
# Default: models/embedding-001
GOOGLE_EMBEDDING_MODEL=models/embedding-001

# Optional: local persistent Chroma DB directory
# Default: <project>/.rag_vector_db
RAG_VECTOR_DB_DIR=.rag_vector_db

# Optional: fixed reference doc path for RAG fallback
# If set and file exists, it is preferred when doc_path is not explicitly provided.
# Example (Windows): C:\Users\anant\docs\Anant_Resume.pdf
# Example (relative): ResearchAgent/reference_docs/anant_resume.pdf
RESEARCH_REFERENCE_DOC_PATH=

# Optional: reference docs directory for auto-discovery fallback
# Default lookup order:
# 1) this env var (if set)
# 2) ResearchAgent/reference_docs
# 3) reference_docs (repo root)
RESEARCH_REFERENCE_DOC_DIR=ResearchAgent/reference_docs

# ---------------------------
# Mode examples
# ---------------------------
# RAG-first + web fallback:
# ENABLE_RAG_RESEARCH=true
# ENABLE_WEB_RESEARCH=true
#
# RAG-only:
# ENABLE_RAG_RESEARCH=true
# ENABLE_WEB_RESEARCH=false
#
# Web-only:
# ENABLE_RAG_RESEARCH=false
# ENABLE_WEB_RESEARCH=true
#
# Disable all research tools:
# ENABLE_RAG_RESEARCH=false
# ENABLE_WEB_RESEARCH=false
